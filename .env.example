# ─── Perpustakaan Universitas Murni Teguh — Environment Variables ─────────────
#
# Copy this file to .env and fill in any values you want to override.
# All variables have sensible defaults; only PORT is required in production.
#
# Usage:
#   cp .env.example .env
#   # edit .env
#   pnpm run build:prod
#   pnpm run start:prod

# ── Server ──────────────────────────────────────────────────────────────────
# Port the Express server listens on.
# Your web server / campus firewall should forward traffic to this port.
PORT=3000

# Set to "production" for live deployments.
NODE_ENV=production

# ── Frontend build ──────────────────────────────────────────────────────────
# URL base for the React app.
#   "/"          → app is served from the domain root  (e.g. https://lib.example.ac.id/)
#   "/library/"  → app is served from a sub-path       (e.g. https://www.example.ac.id/library/)
# Must end with "/" when set to a sub-path.
BASE_PATH=/

# ── Static files (optional override) ────────────────────────────────────────
# Absolute path to the Vite build output directory.
# Leave blank to use the default (artifacts/journal-search/dist/public).
# STATIC_DIR=/var/www/perpustakaan/public

# ── API port (development only) ─────────────────────────────────────────────
# Port the Express backend runs on when using the Vite dev proxy.
# Only relevant during local development; ignored in production.
# API_PORT=8080
